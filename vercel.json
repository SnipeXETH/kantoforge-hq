{
  "functions": {
    "api/sync-shopify.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/sync-shopify",
      "schedule": "0 3 * * *"
    }
  ],
  "rewrites": [
    { "source": "/raffles", "destination": "/index.html" },
    { "source": "/raffles/(.*)", "destination": "/index.html" }
  ]
}
