{
  "functions": {
    "api/sync-shopify.js": {
      "maxDuration": 60
    },
    "api/sync-oddbrew.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/sync-shopify",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/sync-oddbrew",
      "schedule": "30 3 * * *"
    }
  ],
  "rewrites": [
    { "source": "/raffles", "destination": "/api/raffle-og" },
    { "source": "/raffles/:id", "destination": "/api/raffle-og?id=:id" }
  ]
}
