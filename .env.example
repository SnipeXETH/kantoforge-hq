# --- Content generation (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...
CONTENT_NICHE=everyday productivity tips   # default niche if none passed
CONTENT_BATCH_SIZE=4                        # ideas generated per run

# --- Queue store ---
# Default is a JSON file under the OS temp dir (fine for local/dev, ephemeral).
# For production, swap the store in src/lambda/lib/store.js for a durable backend.
QUEUE_DB_PATH=

# --- Video rendering ---
# Point this at an ffmpeg worker that returns { "videoUrl": "https://..." }.
RENDER_WORKER_URL=
# Or, for testing the publish path without a renderer, a fixed public MP4 URL.
PLACEHOLDER_VIDEO_URL=

# --- Publishing ---
PUBLISH_TARGETS=instagram,tiktok            # comma-separated

# Instagram Graph API (Business/Creator account linked to a Facebook Page)
IG_USER_ID=
IG_ACCESS_TOKEN=

# TikTok Content Posting API (pushes to draft inbox for unaudited apps)
TIKTOK_ACCESS_TOKEN=
