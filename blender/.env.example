# Copy this file to ".env" (same folder) and fill it in.

# From Supabase → Settings → API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-keep-this-secret

# Path to the Blender executable. If "blender" already works in your terminal,
# leave it as-is. Otherwise point to it, e.g. on Windows:
#   C:/Program Files/Blender Foundation/Blender 4.2/blender.exe
BLENDER_PATH=blender

# Full path to your .blend template file. Use forward slashes.
# e.g. C:/Users/gjwri/Desktop/KantoForge/.../magnetic_case_BGCROP_rf.blend
KF_TEMPLATE=C:/KantoForge/magnetic_case_BGCROP_rf.blend

# The agent finds the card + background automatically via the Artwork/Cards and
# Artwork/Backgrounds folders next to the .blend — no image names needed.
# Only set these if your folders are named differently:
# KF_CARDS_SUBDIR=Artwork/Cards
# KF_BG_SUBDIR=Artwork/Backgrounds

# This file renders in CYCLES. Optional: cap samples to render faster (lower =
# quicker, grainier). Leave unset to use the file's own quality.
# KF_SAMPLES=128

# How often to check for new jobs (seconds)
KF_POLL_SECONDS=5
